# Backend — copie para .env e preencha. NUNCA commite o .env real (so este template).
# O .env esta no .gitignore; o backend so sobe via up.ps1/run-backend.ps1 (que carregam o .env).

# Banco — DB_PASSWORD e OBRIGATORIO (sem default no application.yml)
DB_USERNAME=postgres
DB_PASSWORD=1234
# Opcional em dev (default = localhost). Producao: jdbc:postgresql://<host>:5432/agendamento
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/agendamento

# Seguranca — OBRIGATORIO (sem default). Gere: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRATION=86400000

# Evolution API (WhatsApp)
EVOLUTION_URL=http://localhost:8080
EVOLUTION_KEY=evolution-api-key
EVOLUTION_INSTANCE=agendabot

# URLs da aplicacao (producao: dominios reais)
APP_BACKEND_URL=http://localhost:8081
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Mercado Pago — vazio = modo MOCK. TEST-... em dev, APP_USR-... so em producao.
MP_ACCESS_TOKEN=
MP_NOTIFICATION_URL=

# Logs
SHOW_SQL=false
